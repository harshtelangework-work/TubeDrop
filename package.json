{
  "name": "tubedrop",
  "version": "1.0.0",
  "description": "TubeDrop YouTube Downloader",
  "main": "main.js",
  "private": true,
  "type": "commonjs",
  "author": "",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --publish never"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.tubedrop.app",
    "productName": "TubeDrop",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!ffmpeg/**/*",
      "!ytdlp/**/*",
      "!server/extension/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "ffmpeg",
        "to": "ffmpeg",
        "filter": ["**/*"]
      },
      {
        "from": "ytdlp",
        "to": "ytdlp",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/TubeDrop.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TubeDrop",
      "artifactName": "TubeDrop Setup.exe",
      "installerIcon": "build/TubeDrop.ico",
      "uninstallerIcon": "build/TubeDrop.ico"
    }
  }
}
